# Server
NODE_ENV=development
PORT=4000

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/anjs?schema=public"

# JWT
JWT_SECRET=change_me_with_a_random_96_chars_string
JWT_EXPIRES_IN=7d

# Admin bootstrap (created on first run if missing)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_EMAIL=admin@anjs.org

# Brevo (transactional email)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@anjs.org
BREVO_SENDER_NAME=Association Nova Jeunesse

# Cloudinary (image hosting CDN)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
